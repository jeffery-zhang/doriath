---
import { withBase } from "../../lib/site";

const homeHref = withBase("/");
const navLinks = [
  { index: "01", label: "博客", href: withBase("/blog/") },
  { index: "02", label: "关于", href: withBase("/about/") }
];
---

<nav class="site-nav">
  <div class="site-nav__inner">
    <a href={homeHref} class="site-brand">
      <span class="display-title site-brand__title">Doriath</span>
      <span class="section-kicker site-brand__subtitle">个人写作档案</span>
    </a>

    <ul class="site-nav__links" aria-label="主导航">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="site-nav__link">
            <span class="site-nav__index">{link.index}</span>
            <span class="site-nav__label">{link.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <details class="site-nav__mobile">
      <summary class="action-chip site-nav__summary">导航</summary>
      <div class="grunge-panel site-nav__mobile-panel">
        <ul class="site-nav__mobile-list" aria-label="移动导航">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="site-nav__mobile-link">
                <span class="site-nav__mobile-label">{link.label}</span>
                <span class="site-nav__mobile-index">{link.index}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </details>
  </div>
</nav>
