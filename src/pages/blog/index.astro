---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedBlogPosts } from "../../lib/blog";
import { formatDate, withBase } from "../../lib/site";

const posts = await getPublishedBlogPosts();
---

<BaseLayout
  title="博客"
  description="发布在 doriath 上的笔记与文章。"
>
  <section class="page-hero panel">
    <p class="eyebrow">博客</p>
    <h1>以 Markdown 为先的写作。</h1>
    <p class="lede">
      文章写在 <code>src/content/blog</code> 中，并在构建时通过 Astro content
      collections 编译。
    </p>
  </section>

  <section class="panel">
    <ul class="post-list" role="list">
      {posts.map((post) => (
        <li class="post-card">
          <p class="post-meta">{formatDate(post.data.pubDate)}</p>
          <h2>
            <a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a>
          </h2>
          <p>{post.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
